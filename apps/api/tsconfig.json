{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": [
      "ES2020"
    ],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "./dist",
    "rootDir": "./apps/api/src",
    "declaration": true,
    "sourceMap": true,
    "resolveJsonModule": true,
    "paths": {
      "@cammani/shared": [
        "../../packages/shared/src"
      ]
    }
  },
  "include": [
    "apps/api/src/**/*",
    "packages/shared/src/**/*"
  ],
  "exclude": [
    "node_modules"
  ]
}